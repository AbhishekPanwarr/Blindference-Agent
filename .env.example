# =============================================================================
# Blindference Agent SDK — Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The CLI auto-loads .env via dotenv. No manual configuration needed.
#
# Priority order for private keys (all are checked):
#   1. BLF_PRIVATE_KEY         (recommended)
#   2. BLINDFERENCE_PRIVATE_KEY
#   3. PRIVATE_KEY
#
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Wallet & RPC
# ---------------------------------------------------------------------------

# Arbitrum Sepolia RPC endpoint (required for on-chain transactions)
# Get a free API key at: https://www.alchemy.com/
BLF_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# Agent wallet private key (32-byte hex, 0x-prefixed)
# ⚠️  NEVER commit this to git. Use a fresh wallet with no mainnet funds.
# Generate a new wallet with MetaMask, fund it with Sepolia ETH, then export.
BLF_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ---------------------------------------------------------------------------
# REQUIRED — Service Endpoints
# ---------------------------------------------------------------------------

# Payment Service URL — where inference job payments are processed
# For local development: http://localhost:8001
# For production / shared: https://payment.blindference.xyz
BLF_PAYMENT_URL=https://payment.blindference.xyz

# ICL (Inference Coordination Layer) endpoint
# Defaults to https://icl.blindference.xyz if not set.
# Only override if running a local ICL instance.
BLF_ICL_URL=https://icl.blindference.xyz

# ---------------------------------------------------------------------------
# OPTIONAL — Advanced Configuration
# ---------------------------------------------------------------------------

# Pinata JWT for direct IPFS uploads (only needed if uploading outside ICL)
# Get one at: https://pinata.cloud/keys
# BLF_PINATA_JWT=eyJhbGciOiJIUzI1NiIs...

# IPFS download gateway (defaults to Pinata public gateway)
# BLF_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# Gas price multiplier for Arbitrum Sepolia (default: 1.5 = 50% buffer)
# Increase if you see "max fee per gas less than block base fee" errors.
# BLF_GAS_PRICE_MULTIPLIER=1.5

# ---------------------------------------------------------------------------
# OPTIONAL — Model & Inference Preferences
# ---------------------------------------------------------------------------

# Default model ID when none is specified
# Available models: groq:llama-3.3-70b-versatile, gemini:gemini-2.5-flash,
#                    facebook/opt-125m
# BLF_DEFAULT_MODEL=groq:llama-3.3-70b-versatile

# Number of verifiers in the quorum (default: 2)
# BLF_VERIFIER_COUNT=2

# Minimum node tier for quorum selection (default: 0)
# Tier 0 = 4GB VRAM (e.g. RTX 3050), Tier 1 = 8GB+, Tier 2 = 16GB+
# BLF_MIN_TIER=0

# Enable insurance / coverage for inference jobs (default: false)
# BLF_INSURANCE=false

# ---------------------------------------------------------------------------
# OPTIONAL — Development / Testing
# ---------------------------------------------------------------------------

# Mock mode — skips all encryption and submits plaintext.
# ⚠️  NEVER use for sensitive data. Only for CI pipelines and local testing.
# BLF_MOCK=false

# Log level: debug, info, warn, error (default: info)
# BLF_LOG_LEVEL=info

# Local CoFHE storage path (defaults to ~/.blindference-cofhe/)
# BLF_COFHE_STORAGE_DIR=~/.blindference-cofhe

# ---------------------------------------------------------------------------
# OPTIONAL — Server Configuration (when running `blindference-agent start`)
# ---------------------------------------------------------------------------

# Port for the local REST server (default: 4000)
# BLF_SERVER_PORT=4000

# CORS origins for the REST server (default: * for development)
# BLF_CORS_ORIGINS=http://localhost:3000,https://blindference.xyz

# ---------------------------------------------------------------------------
# OPTIONAL — Python Interop (when calling from Python subprocess)
# ---------------------------------------------------------------------------

# Path to the CoFHE bridge script (auto-discovered if not set)
# Only needed if the bundled bridge script cannot be found.
# BLF_COFHE_BRIDGE_PATH=./scripts/cofhe_bridge.mjs

# ---------------------------------------------------------------------------
# NOTES
# ---------------------------------------------------------------------------
#
# 1. Get Testnet ETH:
#    - Alchemy Sepolia Faucet: https://sepoliafaucet.com/
#    - QuickNode Faucet: https://faucet.quicknode.com/ethereum/sepolia
