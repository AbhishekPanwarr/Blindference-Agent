# =============================================================================
# Blindference Agent SDK — Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The CLI auto-loads .env via dotenv. No manual configuration needed.
#
# Priority order for private keys (all are checked):
#   1. BLF_PRIVATE_KEY         (recommended)
#   2. BLINDFERENCE_PRIVATE_KEY
#   3. PRIVATE_KEY
#
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Wallet & RPC
# ---------------------------------------------------------------------------

# Arbitrum Sepolia RPC endpoint (required for on-chain transactions)
# Get a free API key at: https://www.alchemy.com/
BLF_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# Agent wallet private key (32-byte hex, 0x-prefixed OR raw hex)
# ⚠️  NEVER commit this to git. Use a fresh wallet with no mainnet funds.
# Generate a new wallet with MetaMask, fund it with Sepolia ETH, then export.
# The SDK automatically adds "0x" if missing.
BLF_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ---------------------------------------------------------------------------
# REQUIRED — Service Endpoints (PRODUCTION)
# ---------------------------------------------------------------------------
#
# These are the PRODUCTION endpoints for the Blindference network.
# Use these when connecting to the live testnet deployment.
#
# Payment Service — processes inference job payments and credits
BLF_PAYMENT_URL=https://payment.blindference.xyz

# ICL (Inference Coordination Layer) — selects quorum nodes, aggregates results
BLF_ICL_URL=https://icl.blindference.xyz
#
# ---------------------------------------------------------------------------
# LOCAL DEVELOPMENT (uncomment if running ICL + Payment Service locally)
# ---------------------------------------------------------------------------
# BLF_PAYMENT_URL=http://127.0.0.1:8001
# BLF_ICL_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# OPTIONAL — Contract Addresses (Arbitrum Sepolia)
# ---------------------------------------------------------------------------
#
# These defaults match the frontend/ICL deployed contracts.
# Override only if you have deployed your own or the network has migrated.
#
# PromptKeyStore — stores CoFHE-encrypted AES key halves for text inference
# BLF_PROMPT_KEY_STORE_ADDRESS=0x7120fAbdAD2FC5B05CD814A59457eB5fCd9Cfa7E
#
# cUSDC token address — payment currency for inference credits
# BLF_CUSDC_TOKEN_ADDRESS=0x42E47f9bA89712C317f60A72C81A610A2b68c48a
#
# BLIND token address — for purchasing credit packages
# BLF_BLIND_TOKEN_ADDRESS=0x232D5470DaaC7AD552a42d876aDEF1f778033cE0
#
# Payment wallet address — where inference fees are sent
# BLF_PAYMENT_WALLET_ADDRESS=0x7F9B413Da50e72415b16Eb9df6e5E59774a338dc

# ---------------------------------------------------------------------------
# OPTIONAL — Advanced Configuration
# ---------------------------------------------------------------------------

# Pinata JWT for direct IPFS uploads (only needed if uploading outside ICL)
# Get one at: https://pinata.cloud/keys
# BLF_PINATA_JWT=eyJhbGciOiJIUzI1NiIs...

# IPFS download gateway (defaults to Pinata public gateway)
# BLF_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# Gas price multiplier for Arbitrum Sepolia (default: 1.5 = 50% buffer)
# Increase if you see "max fee per gas less than block base fee" errors.
# BLF_GAS_PRICE_MULTIPLIER=1.5

# ---------------------------------------------------------------------------
# OPTIONAL — Model & Inference Preferences
# ---------------------------------------------------------------------------

# Default model ID when none is specified
# Available models: groq:llama-3.3-70b-versatile, gemini:gemini-2.5-flash,
#                    facebook/opt-125m
# BLF_DEFAULT_MODEL=groq:llama-3.3-70b-versatile

# Number of verifiers in the quorum (default: 2)
# BLF_VERIFIER_COUNT=2

# Minimum node tier for quorum selection (default: 0)
# Tier 0 = 4GB VRAM (e.g. RTX 3050), Tier 1 = 8GB+, Tier 2 = 16GB+
# BLF_MIN_TIER=0

# Enable insurance / coverage for inference jobs (default: false)
# BLF_INSURANCE=false

# ---------------------------------------------------------------------------
# OPTIONAL — Development / Testing
# ---------------------------------------------------------------------------

# Log level: debug, info, warn, error (default: info)
# BLF_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# OPTIONAL — Server Configuration (when running `blindference-agent start`)
# ---------------------------------------------------------------------------

# Port for the local REST server (default: 4000)
# BLF_SERVER_PORT=4000

# CORS origins for the REST server (default: * for development)
# BLF_CORS_ORIGINS=http://localhost:3000,https://blindference.xyz

# ---------------------------------------------------------------------------
# NOTES
# ---------------------------------------------------------------------------
#
# 1. Get Testnet ETH:
#    - Alchemy Sepolia Faucet: https://sepoliafaucet.com/
#    - QuickNode Faucet: https://faucet.quicknode.com/ethereum/sepolia
#    - Google Cloud Faucet: https://cloud.google.com/application/web3/faucet/ethereum/sepolia
#
# 2. Get BLIND Tokens:
#    - Blindference Faucet: https://blindference.xyz/faucet
#
# 3. Get cUSDC Credits:
#    - Purchase with BLIND: `blindference-agent buy-package --id starter`
#    - Or wrap USDC → cUSDC via the frontend at https://blindference.xyz
#
# 4. Verify Setup:
#    - TypeScript: `npx @blindference/agent-sdk balance`
#
# 5. Arbitrum Sepolia Network Details:
#    - Network Name: Arbitrum Sepolia
#    - RPC URL: https://sepolia-rollup.arbitrum.io/rpc (public) or your Alchemy URL
#    - Chain ID: 421614
#    - Currency Symbol: ETH
#    - Block Explorer: https://sepolia.arbiscan.io
#
# =============================================================================
