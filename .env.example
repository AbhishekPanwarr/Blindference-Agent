# Blindference Agent SDK — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or let the SDK auto-load it when you import blindference_agent.

# ---------------------------------------------------------------------------
# Required for end-to-end encrypted inference
# ---------------------------------------------------------------------------

# Arbitrum Sepolia RPC endpoint with API key
# Get a free key at: https://www.alchemy.com/
BLF_COFHE_RPC=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Agent wallet private key (32-byte hex, 0x-prefixed)
# Generate a fresh wallet or use an existing one
BLF_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ---------------------------------------------------------------------------
# Optional — defaults are fine for most users
# ---------------------------------------------------------------------------

# ICL (Inference Coordination Layer) endpoint
# BLF_ICL_URL=https://icl.blindference.xyz

# Path to CoFHE bridge script (auto-discovered if not set)
# BLF_COFHE_BRIDGE_PATH=./cofhe_bridge.mjs
